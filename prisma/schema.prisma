generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── STORE SETTINGS ─────────────────────────────────────────────────────────

model StoreSettings {
  id                    String   @id @default("singleton")
  storeName             String   @default("Artisans Stories")
  storeDescription      String?
  storeLogo             String?
  storeFavicon          String?
  primaryColor          String   @default("#8B6914")
  accentColor           String   @default("#C9A84C")
  fontHeading           String   @default("Cormorant Garamond")
  fontBody              String   @default("Inter")
  contactEmail          String   @default("hello@artisansstories.com")
  contactPhone          String?
  returnPolicyDays      Int      @default(30)
  returnPolicyText      String?
  storeEnabled          Boolean  @default(false)
  instagramUrl          String?
  tiktokUrl             String?
  facebookUrl           String?
  pinterestUrl          String?
  metaTitle             String?
  metaDescription       String?
  googleAnalyticsId     String?
  facebookPixelId       String?
  lowStockThreshold     Int      @default(5)
  lowStockAlertEmail    String?
  orderNotificationEmail String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ─── ADMIN USERS ────────────────────────────────────────────────────────────

model AdminUser {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  role      AdminRole @default(EDITOR)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

// ─── MAGIC LINK TOKENS ───────────────────────────────────────────────────────

model MagicLinkToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  type      TokenType @default(CUSTOMER)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([token])
}

enum TokenType {
  ADMIN
  CUSTOMER
}

// ─── CATEGORIES ─────────────────────────────────────────────────────────────

model Category {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  description String?
  imageUrl    String?
  parentId    String?
  parent      Category?         @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[]        @relation("CategoryTree")
  position    Int               @default(0)
  isActive    Boolean           @default(true)
  products    ProductCategory[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

// ─── PRODUCTS ────────────────────────────────────────────────────────────────

model Product {
  id               String            @id @default(cuid())
  slug             String            @unique
  name             String
  description      String?
  story            String?
  status           ProductStatus     @default(DRAFT)
  price            Int
  compareAtPrice   Int?
  costPrice        Int?
  sku              String?           @unique
  barcode          String?
  weight           Float?
  weightUnit       String            @default("oz")
  length           Float?
  width            Float?
  height           Float?
  dimensionUnit    String            @default("in")
  tags             String[]
  artisanName      String?
  originCountry    String            @default("El Salvador")
  materialsUsed    String[]
  isFeatured       Boolean           @default(false)
  isDigital        Boolean           @default(false)
  requiresShipping Boolean           @default(true)
  taxCategory      String?
  taxCode          String?
  seoTitle         String?
  seoDescription   String?
  totalSold        Int               @default(0)
  categories       ProductCategory[]
  variants         ProductVariant[]
  images           ProductImage[]
  options          ProductOption[]
  orderItems       OrderItem[]
  reviews          Review[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model ProductOption {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  values    String[]
  position  Int      @default(0)
  createdAt DateTime @default(now())
}

model ProductVariant {
  id              String         @id @default(cuid())
  productId       String
  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  name            String
  optionValues    Json
  sku             String?        @unique
  barcode         String?
  price           Int?
  costPrice       Int?
  weight          Float?
  stripeProductId String?
  stripePriceId   String?
  position        Int            @default(0)
  images          ProductImage[]
  inventory       Inventory?
  orderItems      OrderItem[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ProductImage {
  id        String          @id @default(cuid())
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  url       String
  urlThumb  String?
  urlMedium String?
  altText   String?
  position  Int             @default(0)
  width     Int?
  height    Int?
  size      Int?
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())
}

// ─── INVENTORY ───────────────────────────────────────────────────────────────

model Inventory {
  id                String         @id @default(cuid())
  variantId         String         @unique
  variant           ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity          Int            @default(0)
  reservedQuantity  Int            @default(0)
  lowStockThreshold Int            @default(5)
  trackedInventory  Boolean        @default(true)
  allowBackorder    Boolean        @default(false)
  updatedAt         DateTime       @updatedAt
  logs              InventoryLog[]
}

model InventoryLog {
  id          String    @id @default(cuid())
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  delta       Int
  reason      String
  note        String?
  createdAt   DateTime  @default(now())
}

// ─── CUSTOMERS ───────────────────────────────────────────────────────────────

model Customer {
  id               String    @id @default(cuid())
  email            String    @unique
  firstName        String?
  lastName         String?
  phone            String?
  acceptsMarketing Boolean   @default(false)
  stripeCustomerId String?
  totalOrders      Int       @default(0)
  totalSpent       Int       @default(0)
  notes            String?
  tags             String[]
  addresses        Address[]
  orders           Order[]
  reviews          Review[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastOrderAt      DateTime?
}

model Address {
  id          String      @id @default(cuid())
  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type        AddressType @default(SHIPPING)
  firstName   String
  lastName    String
  company     String?
  address1    String
  address2    String?
  city        String
  state       String
  stateCode   String
  zip         String
  country     String      @default("United States")
  countryCode String      @default("US")
  phone       String?
  isDefault   Boolean     @default(false)
  createdAt   DateTime    @default(now())
}

enum AddressType {
  SHIPPING
  BILLING
}

// ─── ORDERS ──────────────────────────────────────────────────────────────────

model Order {
  id                      String          @id @default(cuid())
  orderNumber             String          @unique
  customerId              String?
  customer                Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  status                  OrderStatus     @default(PENDING)
  financialStatus         FinancialStatus @default(PENDING)
  email                   String
  phone                   String?
  shippingAddress         Json
  billingAddress          Json?
  subtotal                Int
  discountTotal           Int             @default(0)
  shippingTotal           Int             @default(0)
  taxTotal                Int             @default(0)
  total                   Int
  currency                String          @default("usd")
  stripePaymentIntentId   String?
  stripeCheckoutSessionId String?
  discountCode            String?
  customerNote            String?
  adminNote               String?
  tags                    String[]
  source                  OrderSource     @default(WEB)
  cancelledAt             DateTime?
  cancelReason            String?
  items                   OrderItem[]
  fulfillments            Fulfillment[]
  returns                 Return[]
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
}

enum OrderStatus {
  PENDING
  PROCESSING
  FULFILLED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum FinancialStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  REFUNDED
  PARTIALLY_REFUNDED
  VOIDED
}

enum OrderSource {
  WEB
  ADMIN
  IMPORT
}

model OrderItem {
  id                String          @id @default(cuid())
  orderId           String
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId         String?
  product           Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId         String?
  variant           ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  title             String
  variantTitle      String?
  sku               String?
  quantity          Int
  price             Int
  totalDiscount     Int             @default(0)
  total             Int
  productSnapshot   Json
  requiresShipping  Boolean         @default(true)
  fulfillmentStatus String?
  returnItems       ReturnItem[]
  createdAt         DateTime        @default(now())
}

// ─── FULFILLMENTS ────────────────────────────────────────────────────────────

model Fulfillment {
  id                String            @id @default(cuid())
  orderId           String
  order             Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status            FulfillmentStatus @default(PENDING)
  trackingCompany   String?
  trackingNumber    String?
  trackingUrl       String?
  carrier           String?
  service           String?
  shippedAt         DateTime?
  estimatedDelivery DateTime?
  notifyCustomer    Boolean           @default(true)
  items             Json
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

enum FulfillmentStatus {
  PENDING
  OPEN
  SUCCESS
  CANCELLED
  ERROR
}

// ─── RETURNS ─────────────────────────────────────────────────────────────────

model Return {
  id             String       @id @default(cuid())
  orderId        String
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status         ReturnStatus @default(REQUESTED)
  customerNote   String?
  adminNote      String?
  refundAmount   Int?
  restockItems   Boolean      @default(true)
  stripeRefundId String?
  items          ReturnItem[]
  requestedAt    DateTime     @default(now())
  resolvedAt     DateTime?
  updatedAt      DateTime     @updatedAt
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  RECEIVED
  REFUNDED
}

model ReturnItem {
  id          String       @id @default(cuid())
  returnId    String
  return      Return       @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItemId String
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  quantity    Int
  reason      ReturnReason
  note        String?
}

enum ReturnReason {
  DEFECTIVE
  WRONG_ITEM
  NOT_AS_DESCRIBED
  CHANGED_MIND
  OTHER
}

// ─── DISCOUNTS ───────────────────────────────────────────────────────────────

model Discount {
  id                 String       @id @default(cuid())
  code               String       @unique
  type               DiscountType
  value              Int
  minimumOrderAmount Int?
  appliesToAll       Boolean      @default(true)
  productIds         String[]
  categoryIds        String[]
  usageLimit         Int?
  usageCount         Int          @default(0)
  perCustomerLimit   Int?
  startsAt           DateTime?
  endsAt             DateTime?
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

// ─── SHIPPING ────────────────────────────────────────────────────────────────

model ShippingZone {
  id        String         @id @default(cuid())
  name      String
  countries String[]
  regions   String[]
  rates     ShippingRate[]
  isActive  Boolean        @default(true)
  position  Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ShippingRate {
  id        String        @id @default(cuid())
  zoneId    String
  zone      ShippingZone  @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name      String
  condition RateCondition @default(FLAT)
  minValue  Float?
  maxValue  Float?
  price     Int
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
}

enum RateCondition {
  FLAT
  WEIGHT
  ORDER_VALUE
  FREE
}

// ─── REVIEWS ─────────────────────────────────────────────────────────────────

model Review {
  id               String       @id @default(cuid())
  productId        String
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId       String?
  customer         Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  orderId          String?
  rating           Int
  title            String?
  body             String?
  status           ReviewStatus @default(PENDING)
  verifiedPurchase Boolean      @default(false)
  helpfulCount     Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}
